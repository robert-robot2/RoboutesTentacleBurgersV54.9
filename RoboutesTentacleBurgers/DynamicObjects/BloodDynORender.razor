






<!-- Dynamic Objects -->
@foreach (var registry in BloodDynOHandle.AllRegistries)
{
    foreach (var dynObj in registry.Where(p => p.DynIsActive))
    {
        // Flag if this is the currently active dynamic object
        var isActive = ActiveDynO != null && ReferenceEquals(dynObj, ActiveDynO);

        // Only render if the object exists
        if (dynObj != null)
        {
            <div style="@dynObj.DynSpriteStyle"></div>
        }
    }
}


@code {
 

    [Parameter] public BloodDynOHandle? DynOHandle { get; set; } 
    public IDynamicO? ActiveDynO => DynOHandle?.ActiveDynO;
   

}











