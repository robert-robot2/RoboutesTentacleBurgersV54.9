
@page "/Tetris40k"
<PageTitle>Tetris40k</PageTitle>

<div class="DiabloBlueGlow" style="font-size:150%">Tetris 40K: For The Emperor!</div>


@using System.Timers
@using Microsoft.AspNetCore.Components.Forms
@implements IDisposable


<div class="game-container">
    <div class="game-header">
        <h1>🎮 TETRIS</h1>

        <div class="image-upload-section">
            <h3>Custom Block Images</h3>
            <div class="upload-grid">
                <label>
                    I-Piece (Cyan):
                    <InputFile OnChange="e => LoadImageData(e, 0)" accept="image/png,image/jpg,image/jpeg" />
                </label>
                <label>
                    O-Piece (Yellow):
                    <InputFile OnChange="e => LoadImageData(e, 1)" accept="image/png,image/jpg,image/jpeg" />
                </label>
                <label>
                    T-Piece (Purple):
                    <InputFile OnChange="e => LoadImageData(e, 2)" accept="image/png,image/jpg,image/jpeg" />
                </label>
                <label>
                    S-Piece (Green):
                    <InputFile OnChange="e => LoadImageData(e, 3)" accept="image/png,image/jpg,image/jpeg" />
                </label>
                <label>
                    Z-Piece (Red):
                    <InputFile OnChange="e => LoadImageData(e, 4)" accept="image/png,image/jpg,image/jpeg" />
                </label>
                <label>
                    L-Piece (Orange):
                    <InputFile OnChange="e => LoadImageData(e, 5)" accept="image/png,image/jpg,image/jpeg" />
                </label>
                <label>
                    J-Piece (Blue):
                    <InputFile OnChange="e => LoadImageData(e, 6)" accept="image/png,image/jpg,image/jpeg" />
                </label>
            </div>
        </div>

        <div class="stats">
            <div class="stat">
                <span class="label">Score:</span>
                <span class="value">@score</span>
            </div>
            <div class="stat">
                <span class="label">Level:</span>
                <span class="value">@level</span>
            </div>
            <div class="stat">
                <span class="label">Lines:</span>
                <span class="value">@linesCleared</span>
            </div>
        </div>
    </div>

    <div class="game-area">
        <div class="board-container">
            @if (gameOver)
            {
                <div class="game-over-overlay">
                    <h2>GAME OVER</h2>
                    <p>Score: @score</p>
                    <button @onclick="StartGame">Play Again</button>
                </div>
            }
            else if (!gameStarted)
            {
                <div class="game-over-overlay">
                    <h2>TETRIS</h2>
                    <p>Press Start to Play</p>
                    <button @onclick="StartGame">Start Game</button>
                </div>
            }

            <svg width="@(COLS* CELL_SIZE)" height="@(ROWS* CELL_SIZE)" class="board"
                 tabindex="0" @onkeydown="HandleKeyDown" @ref="boardElement">
                <defs>
                    @foreach (var color in pieceColors)
                    {
                        <filter id="glow-@color.Replace("#", "")">
                            <feGaussianBlur stdDeviation="3" result="coloredBlur" />
                            <feMerge>
                                <feMergeNode in="coloredBlur" />
                                <feMergeNode in="coloredBlur" />
                                <feMergeNode in="SourceGraphic" />
                            </feMerge>
                        </filter>
                    }
                </defs>

                @* Board cells *@
                @for (int r = 0; r < ROWS; r++)
                {
                    for (int c = 0; c < COLS; c++)
                    {
                        int row = r;
                        int col = c;
                        var cellColor = board[row, col];

                        @if (cellColor != null)
                        {
                            int x = col * CELL_SIZE;
                            int y = row * CELL_SIZE;
                            string cleanColor = cellColor.Replace("#", "");
                            int pieceIndex = Array.IndexOf(pieceColors, cellColor);

                            @if (!string.IsNullOrEmpty(customImages[pieceIndex]))
                            {
                                <image x="@x" y="@y" width="@CELL_SIZE" height="@CELL_SIZE"
                                       href="@customImages[pieceIndex]"
                                       opacity="0.9"
                                       filter="url(#glow-@cleanColor)" />
                            }
                            else
                            {
                                @* Dark inner fill *@
                                <rect x="@(x + 2)" y="@(y + 2)"
                                      width="@(CELL_SIZE - 4)" height="@(CELL_SIZE - 4)"
                                      fill="#111"
                                      opacity="0.8" />

                                @* Colored glowing outline *@
                                <rect x="@(x + 2)" y="@(y + 2)"
                                      width="@(CELL_SIZE - 4)" height="@(CELL_SIZE - 4)"
                                      fill="none"
                                      stroke="@cellColor"
                                      stroke-width="2"
                                      filter="url(#glow-@cleanColor)" />

                                @* Inner grid pattern *@
                                <line x1="@(x + 2)" y1="@(y + CELL_SIZE / 2)"
                                      x2="@(x + CELL_SIZE - 2)" y2="@(y + CELL_SIZE / 2)"
                                      stroke="@cellColor" stroke-width="1" opacity="0.5" />
                                <line x1="@(x + CELL_SIZE / 2)" y1="@(y + 2)"
                                      x2="@(x + CELL_SIZE / 2)" y2="@(y + CELL_SIZE - 2)"
                                      stroke="@cellColor" stroke-width="1" opacity="0.5" />
                            }
                        }
                    }
                }

                @* Current piece *@
                @if (currentPiece != null)
                {
                    for (int r = 0; r < currentPiece.Shape.GetLength(0); r++)
                    {
                        for (int c = 0; c < currentPiece.Shape.GetLength(1); c++)
                        {
                            if (currentPiece.Shape[r, c] == 1)
                            {
                                int x = (currentX + c) * CELL_SIZE;
                                int y = (currentY + r) * CELL_SIZE;
                                string cleanColor = currentPiece.Color.Replace("#", "");

                                @if (!string.IsNullOrEmpty(customImages[currentPiece.ImageIndex]))
                                {
                                    <image x="@x" y="@y" width="@CELL_SIZE" height="@CELL_SIZE"
                                           href="@customImages[currentPiece.ImageIndex]"
                                           opacity="1"
                                           filter="url(#glow-@cleanColor)" />
                                }
                                else
                                {
                                    @* Dark inner fill *@
                                    <rect x="@(x + 2)" y="@(y + 2)"
                                          width="@(CELL_SIZE - 4)" height="@(CELL_SIZE - 4)"
                                          fill="#111"
                                          opacity="0.9" />

                                    @* Colored glowing outline - brighter for current piece *@
                                    <rect x="@(x + 2)" y="@(y + 2)"
                                          width="@(CELL_SIZE - 4)" height="@(CELL_SIZE - 4)"
                                          fill="none"
                                          stroke="@currentPiece.Color"
                                          stroke-width="3"
                                          filter="url(#glow-@cleanColor)" />

                                    @* Inner grid pattern *@
                                    <line x1="@(x + 2)" y1="@(y + CELL_SIZE / 2)"
                                          x2="@(x + CELL_SIZE - 2)" y2="@(y + CELL_SIZE / 2)"
                                          stroke="@currentPiece.Color" stroke-width="1" opacity="0.7" />
                                    <line x1="@(x + CELL_SIZE / 2)" y1="@(y + 2)"
                                          x2="@(x + CELL_SIZE / 2)" y2="@(y + CELL_SIZE - 2)"
                                          stroke="@currentPiece.Color" stroke-width="1" opacity="0.7" />
                                }
                            }
                        }
                    }
                }
            </svg>
        </div>

        <div class="side-panel">
            <div class="next-piece">
                <h3>Next</h3>
                <svg width="120" height="80" class="preview">
                    @if (nextPiece != null)
                    {
                        string cleanColor = nextPiece.Color.Replace("#", "");

                        @for (int r = 0; r < nextPiece.Shape.GetLength(0); r++)
                        {
                            for (int c = 0; c < nextPiece.Shape.GetLength(1); c++)
                            {
                                if (nextPiece.Shape[r, c] == 1)
                                {
                                    int x = c * 20 + 20;
                                    int y = r * 20 + 10;

                                    @if (!string.IsNullOrEmpty(customImages[nextPiece.ImageIndex]))
                                    {
                                        <image x="@(x + 1)" y="@(y + 1)" width="18" height="18"
                                               href="@customImages[nextPiece.ImageIndex]"
                                               opacity="0.9"
                                               filter="url(#glow-@cleanColor)" />
                                    }
                                    else
                                    {
                                        <rect x="@(x + 1)" y="@(y + 1)"
                                              width="18" height="18"
                                              fill="#111"
                                              opacity="0.8" />

                                        <rect x="@(x + 1)" y="@(y + 1)"
                                              width="18" height="18"
                                              fill="none"
                                              stroke="@nextPiece.Color"
                                              stroke-width="2"
                                              filter="url(#glow-@cleanColor)" />

                                        <line x1="@(x + 1)" y1="@(y + 10)"
                                              x2="@(x + 19)" y2="@(y + 10)"
                                              stroke="@nextPiece.Color" stroke-width="1" opacity="0.5" />
                                        <line x1="@(x + 10)" y1="@(y + 1)"
                                              x2="@(x + 10)" y2="@(y + 19)"
                                              stroke="@nextPiece.Color" stroke-width="1" opacity="0.5" />
                                    }
                                }
                            }
                        }
                    }
                </svg>
            </div>

            <div class="controls">
                <h3>Controls</h3>
                <p>← → Move</p>
                <p>↑ Rotate</p>
                <p>↓ Soft Drop</p>
                <p>Space Hard Drop</p>
                <p>P Pause</p>
            </div>

            @if (!gameStarted || gameOver)
            {
                <button class="control-btn" @onclick="StartGame">
                    @(gameOver ? "Restart" : "Start")
                </button>
            }
            else if (paused)
            {
                <button class="control-btn" @onclick="TogglePause">Resume</button>
            }
            else
            {
                <button class="control-btn" @onclick="TogglePause">Pause</button>
            }
        </div>
    </div>
</div>

<style>
    .game-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 20px;
        font-family: 'Arial', sans-serif;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
        color: white;
    }

    .game-header {
        text-align: center;
        margin-bottom: 20px;
        width: 100%;
        max-width: 900px;
    }

        .game-header h1 {
            margin: 0 0 20px 0;
            font-size: 3em;
            text-shadow: 3px 3px 6px rgba(0,0,0,0.3);
        }

    .image-upload-section {
        background: rgba(0,0,0,0.3);
        padding: 15px;
        border-radius: 10px;
        margin-bottom: 15px;
    }

        .image-upload-section h3 {
            margin: 0 0 15px 0;
            font-size: 1.2em;
        }

    .upload-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 10px;
    }

        .upload-grid label {
            display: flex;
            flex-direction: column;
            gap: 5px;
            font-size: 0.9em;
        }

        .upload-grid input[type="file"] {
            font-size: 0.85em;
            padding: 5px;
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.3);
            border-radius: 3px;
            color: white;
        }

    .stats {
        display: flex;
        gap: 30px;
        justify-content: center;
        background: rgba(0,0,0,0.3);
        padding: 15px 30px;
        border-radius: 10px;
    }

    .stat {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

        .stat .label {
            font-size: 0.9em;
            opacity: 0.8;
        }

        .stat .value {
            font-size: 1.8em;
            font-weight: bold;
        }

    .game-area {
        display: flex;
        gap: 20px;
        align-items: flex-start;
    }

    .board-container {
        position: relative;
    }

    .board {
        background: #0f0f1e;
        border: 4px solid #1a1a2e;
        border-radius: 5px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }

        .board:focus {
            outline: 3px solid #ffd700;
        }

    .game-over-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0,0,0,0.9);
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        z-index: 10;
        border-radius: 5px;
    }

        .game-over-overlay h2 {
            font-size: 3em;
            margin: 0 0 20px 0;
            color: #ff6b6b;
        }

        .game-over-overlay p {
            font-size: 1.5em;
            margin: 10px 0 30px 0;
        }

        .game-over-overlay button, .control-btn {
            background: #4ecdc4;
            color: white;
            border: none;
            padding: 15px 40px;
            font-size: 1.2em;
            border-radius: 5px;
            cursor: pointer;
            transition: all 0.3s;
            font-weight: bold;
        }

            .game-over-overlay button:hover, .control-btn:hover {
                background: #45b7aa;
                transform: scale(1.05);
            }

    .side-panel {
        display: flex;
        flex-direction: column;
        gap: 20px;
        width: 200px;
    }

    .next-piece, .controls {
        background: rgba(0,0,0,0.3);
        padding: 15px;
        border-radius: 10px;
    }

        .next-piece h3, .controls h3 {
            margin: 0 0 15px 0;
            text-align: center;
            font-size: 1.3em;
        }

    .preview {
        background: #0f0f1e;
        border: 2px solid #1a1a2e;
        border-radius: 5px;
        display: block;
    }

    .controls p {
        margin: 8px 0;
        font-size: 0.95em;
    }

    .control-btn {
        width: 100%;
        margin-top: 10px;
    }
</style>

@code {
    private const int ROWS = 20;
    private const int COLS = 10;
    private const int CELL_SIZE = 30;
    private const int BASE_SPEED = 800;

    private string[] pieceColors = { "#00f0f0", "#f0f000", "#a000f0", "#00f000", "#f00000", "#f0a000", "#0000f0" };
    private string[] customImages = new string[7];
    private string?[,] board = new string?[ROWS, COLS];
    private Tetromino? currentPiece;
    private Tetromino? nextPiece;
    private int currentX = 0;
    private int currentY = 0;
    private bool gameStarted = false;
    private bool gameOver = false;
    private bool paused = false;
    private int score = 0;
    private int level = 1;
    private int linesCleared = 0;
    private Timer? gameTimer;
    private ElementReference boardElement;

    protected override void OnInitialized()
    {
        InitBoard();
        nextPiece = GetRandomPiece();
    }

    private async Task LoadImageData(InputFileChangeEventArgs e, int index)
    {
        var file = e.File;
        if (file != null)
        {
            var buffer = new byte[file.Size];
            await file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024).ReadAsync(buffer);
            var base64 = Convert.ToBase64String(buffer);
            customImages[index] = $"data:{file.ContentType};base64,{base64}";
            StateHasChanged();
        }
    }

    private void InitBoard()
    {
        board = new string?[ROWS, COLS];
    }

    private void StartGame()
    {
        InitBoard();
        score = 0;
        level = 1;
        linesCleared = 0;
        gameOver = false;
        gameStarted = true;
        paused = false;

        currentPiece = nextPiece ?? GetRandomPiece();
        nextPiece = GetRandomPiece();
        SpawnPiece();

        gameTimer?.Dispose();
        gameTimer = new Timer(GetSpeed());
        gameTimer.Elapsed += GameTick;
        gameTimer.AutoReset = true;
        gameTimer.Start();
    }

    private void TogglePause()
    {
        paused = !paused;
        if (paused)
        {
            gameTimer?.Stop();
        }
        else
        {
            gameTimer?.Start();
        }
    }

    private int GetSpeed()
    {
        return Math.Max(100, BASE_SPEED - (level - 1) * 50);
    }

    private void GameTick(object? sender, ElapsedEventArgs e)
    {
        InvokeAsync(() =>
        {
            if (!paused && !gameOver)
            {
                MoveDown();
                StateHasChanged();
            }
        });
    }

    private void SpawnPiece()
    {
        currentX = COLS / 2 - 1;
        currentY = 0;

        if (!CanMove(currentX, currentY, currentPiece!.Shape))
        {
            gameOver = true;
            gameTimer?.Stop();
        }
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (!gameStarted || gameOver || paused) return;

        switch (e.Key)
        {
            case "ArrowLeft":
                MoveLeft();
                break;
            case "ArrowRight":
                MoveRight();
                break;
            case "ArrowDown":
                MoveDown();
                break;
            case "ArrowUp":
                Rotate();
                break;
            case " ":
                HardDrop();
                break;
            case "p":
            case "P":
                TogglePause();
                break;
        }
    }

    private void MoveLeft()
    {
        if (CanMove(currentX - 1, currentY, currentPiece!.Shape))
        {
            currentX--;
        }
    }

    private void MoveRight()
    {
        if (CanMove(currentX + 1, currentY, currentPiece!.Shape))
        {
            currentX++;
        }
    }

    private void MoveDown()
    {
        if (CanMove(currentX, currentY + 1, currentPiece!.Shape))
        {
            currentY++;
        }
        else
        {
            LockPiece();
            ClearLines();
            currentPiece = nextPiece;
            nextPiece = GetRandomPiece();
            SpawnPiece();
        }
    }

    private void HardDrop()
    {
        while (CanMove(currentX, currentY + 1, currentPiece!.Shape))
        {
            currentY++;
            score += 2;
        }
        LockPiece();
        ClearLines();
        currentPiece = nextPiece;
        nextPiece = GetRandomPiece();
        SpawnPiece();
    }

    private void Rotate()
    {
        var rotated = RotateMatrix(currentPiece!.Shape);
        if (CanMove(currentX, currentY, rotated))
        {
            currentPiece.Shape = rotated;
        }
    }

    private int[,] RotateMatrix(int[,] matrix)
    {
        int rows = matrix.GetLength(0);
        int cols = matrix.GetLength(1);
        int[,] rotated = new int[cols, rows];

        for (int r = 0; r < rows; r++)
        {
            for (int c = 0; c < cols; c++)
            {
                rotated[c, rows - 1 - r] = matrix[r, c];
            }
        }

        return rotated;
    }

    private bool CanMove(int x, int y, int[,] shape)
    {
        for (int r = 0; r < shape.GetLength(0); r++)
        {
            for (int c = 0; c < shape.GetLength(1); c++)
            {
                if (shape[r, c] == 1)
                {
                    int boardX = x + c;
                    int boardY = y + r;

                    if (boardX < 0 || boardX >= COLS || boardY >= ROWS)
                        return false;

                    if (boardY >= 0 && board[boardY, boardX] != null)
                        return false;
                }
            }
        }
        return true;
    }

    private void LockPiece()
    {
        for (int r = 0; r < currentPiece!.Shape.GetLength(0); r++)
        {
            for (int c = 0; c < currentPiece.Shape.GetLength(1); c++)
            {
                if (currentPiece.Shape[r, c] == 1)
                {
                    int boardX = currentX + c;
                    int boardY = currentY + r;
                    if (boardY >= 0 && boardY < ROWS && boardX >= 0 && boardX < COLS)
                    {
                        board[boardY, boardX] = currentPiece.Color;
                    }
                }
            }
        }
    }

    private void ClearLines()
    {
        int cleared = 0;
        for (int r = ROWS - 1; r >= 0; r--)
        {
            bool fullLine = true;
            for (int c = 0; c < COLS; c++)
            {
                if (board[r, c] == null)
                {
                    fullLine = false;
                    break;
                }
            }

            if (fullLine)
            {
                cleared++;
                for (int row = r; row > 0; row--)
                {
                    for (int c = 0; c < COLS; c++)
                    {
                        board[row, c] = board[row - 1, c];
                    }
                }
                for (int c = 0; c < COLS; c++)
                {
                    board[0, c] = null;
                }
                r++;
            }
        }

        if (cleared > 0)
        {
            linesCleared += cleared;
            score += cleared * cleared * 100 * level;
            level = linesCleared / 10 + 1;

            gameTimer?.Dispose();
            gameTimer = new Timer(GetSpeed());
            gameTimer.Elapsed += GameTick;
            gameTimer.AutoReset = true;
            gameTimer.Start();
        }
    }

    private Tetromino GetRandomPiece()
    {
        var random = new Random();
        var pieces = new[]
        {
            new Tetromino { Shape = new[,] { {1,1,1,1} }, Color = pieceColors[0], ImageIndex = 0 }, // I - Cyan
            new Tetromino { Shape = new[,] { {1,1}, {1,1} }, Color = pieceColors[1], ImageIndex = 1 }, // O - Yellow
            new Tetromino { Shape = new[,] { {0,1,0}, {1,1,1} }, Color = pieceColors[2], ImageIndex = 2 }, // T - Purple
            new Tetromino { Shape = new[,] { {1,1,0}, {0,1,1} }, Color = pieceColors[3], ImageIndex = 3 }, // S - Green
            new Tetromino { Shape = new[,] { {0,1,1}, {1,1,0} }, Color = pieceColors[4], ImageIndex = 4 }, // Z - Red
            new Tetromino { Shape = new[,] { {1,0,0}, {1,1,1} }, Color = pieceColors[5], ImageIndex = 5 }, // L - Orange
            new Tetromino { Shape = new[,] { {0,0,1}, {1,1,1} }, Color = pieceColors[6], ImageIndex = 6 }  // J - Blue
        };
        return pieces[random.Next(pieces.Length)];
    }

    public void Dispose()
    {
        gameTimer?.Dispose();
    }

    private class Tetromino
    {
        public int[,] Shape { get; set; } = new int[0, 0];
        public string Color { get; set; } = "";
        public int ImageIndex { get; set; }
    }
}