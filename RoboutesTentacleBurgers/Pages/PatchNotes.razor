


<div class="patch-notes-container">
    @foreach (var note in PatchNoteEntries)
    {
        <div class="patch-note-block">
            <div class="patch-title">@note.Title</div>
            <div class="patch-body">
                @foreach (var line in note.Lines)
                {
                    <div class="patch-line">@line</div>
                }
            </div>
        </div>
    }
</div>

