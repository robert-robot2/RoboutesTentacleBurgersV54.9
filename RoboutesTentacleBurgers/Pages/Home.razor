@code {
    private string healMessage = "";
    private double healOpacity = 0;
    private System.Timers.Timer? fadeTimer;
        private double glowPhase = 0;
    private System.Timers.Timer? glowTimer;

    protected override void OnInitialized()
    {
        glowTimer = new System.Timers.Timer(16); // ~60 FPS
        glowTimer.Elapsed += (_, __) => InvokeAsync(() =>
        {
            glowPhase += 0.05;
            if (glowPhase > Math.PI * 2)
                glowPhase = 0;

            StateHasChanged();
        });
        glowTimer.Start();
    }

    private string GetGlowStyle()
    {
        // Oscillate between 0 and 1
        double t = (Math.Sin(glowPhase) + 1) / 2;

        // Interpolate glow radius
        int glowA = (int)(10 + t * 10);  // 10 → 20
        int glowB = (int)(20 + t * 10);  // 20 → 30
        int glowC = (int)(30 + t * 10);  // 30 → 40

        // Interpolate color
        string colorA = "#e60073";
        string colorB = "#ff4da6";

        // Pick color based on t
        string glowColor = t < 0.5 ? colorA : colorB;

        return $"text-shadow: 0 0 {glowA}px #fff, 0 0 {glowB}px #fff, 0 0 {glowC}px {glowColor};";
    }

    public void Dispose()
    {
        glowTimer?.Dispose();
    }
    private void TriggerHeal()
    {
        healMessage = "+5 HP";
        healOpacity = 1;

        fadeTimer?.Dispose();
        fadeTimer = new System.Timers.Timer(1500);
        fadeTimer.Elapsed += (_, __) => InvokeAsync(() =>
        {
            healOpacity = 0;
            StateHasChanged();
        });
        fadeTimer.AutoReset = false;
        fadeTimer.Start();

    }

   
}










