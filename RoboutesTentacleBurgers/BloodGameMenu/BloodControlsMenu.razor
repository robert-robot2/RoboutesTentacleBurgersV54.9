            <input class="bloodwyrm-input"
                   type="text"
                   value="@KeybindConfig.GetBinding("Performance")"
                   tabindex="0"
                   @onclick="@(() => activeAction = "Performance")"
                   @onkeydown="CaptureKey" />
        </td>
    </tr>
    <tr>

        <td>PlaceHolder For GamePad Binds</td></tr>
</table>

<button class="glow-button4" @onclick="OnRMainMenuPressed">Main Menu</button>

@code {
    private string? activeAction;

    private void CaptureKey(KeyboardEventArgs e)
    {
        if (string.IsNullOrEmpty(activeAction)) return;

        KeybindConfig.SetBinding(activeAction, e.Key);
        activeAction = null;
    }



    [Parameter] public EventCallback OnRMainMenu { get; set; }
    private async Task OnRMainMenuPressed()
    {
        await OnRMainMenu.InvokeAsync();
    }

   
}
