<div class="bloodwyrm-title">
    Controls
</div>

<table class="bloodwyrm-subtitletext">
    <tr>
        <td>Move Up:</td>
        <td>
            <input class="bloodwyrm-input"
                   type="text"
                   value="@KeybindConfig.GetBinding("MoveUp")"
                   tabindex="0"
                   @onclick="@(() => activeAction = "MoveUp")"
                   @onkeydown="CaptureKey" />
        </td>
    </tr>
    <tr>
        <td>Move Down:</td>
        <td>
            <input class="bloodwyrm-input"
                   type="text"
                   value="@KeybindConfig.GetBinding("MoveDown")"
                   tabindex="0"
                   @onclick="@(() => activeAction = "MoveDown")"
                   @onkeydown="CaptureKey" />
        </td>
    </tr>
    <tr>
        <td>Move Left:</td>
        <td>
            <input class="bloodwyrm-input"
                   type="text"
