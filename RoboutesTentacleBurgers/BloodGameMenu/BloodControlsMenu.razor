                   tabindex="0"
                   @onclick="@(() => activeAction = "MoveLeft")"
                   @onkeydown="CaptureKey" />
        </td>
    </tr>
    <tr>
        <td>Move Right:</td>
        <td>
            <input class="bloodwyrm-input"
                   type="text"
                   value="@KeybindConfig.GetBinding("MoveRight")"
                   tabindex="0"
                   @onclick="@(() => activeAction = "MoveRight")"
                   @onkeydown="CaptureKey" />
        </td>
    </tr>
    <tr>
        <td>Attack:</td>
        <td>
            <input class="bloodwyrm-input"
                   type="text"
                   value="@KeybindConfig.GetBinding("Attack")"
                   tabindex="0"
                   @onclick="@(() => activeAction = "Attack")"
                   @onkeydown="CaptureKey" />
        </td>
    </tr>
    <tr>
        <td>SpAttack:</td>
        <td>
            <input class="bloodwyrm-input"
                   type="text"
                   value="@KeybindConfig.GetBinding("SPAttack")"
                   tabindex="0"
                   @onclick="@(() => activeAction = "SPAttack")"
                   @onkeydown="CaptureKey" />
        </td>
    </tr>
    <tr>
        <td>Menu:</td>
        <td>
            <input class="bloodwyrm-input"
                   type="text"
                   value="@KeybindConfig.GetBinding("Menu")"
                   tabindex="0"
                   @onclick="@(() => activeAction = "Menu")"
                   @onkeydown="CaptureKey" />
        </td>
    </tr>
    <tr>
        <td>Inventory:</td>
        <td>
            <input class="bloodwyrm-input"
                   type="text"
