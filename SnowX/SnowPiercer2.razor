                        <rect x="@x" y="@y" width="192" height="64" fill="@carColor" stroke="#000" stroke-width="2" />
                        <circle cx="@(x + 38)" cy="@(y + 64)" r="15" fill="#333" />
                        <circle cx="@(x + 154)" cy="@(y + 64)" r="15" fill="#333" />

                        @if (carInstance.Type != "engine")
                        {
                            <g>
                                <text x="@(x + 96)" y="@(y + 35)" fill="#fff" font-size="16"
                                      font-family="Arial" text-anchor="middle">@carInstance.Type.ToUpper()</text>
                            </g>
                        }
                    }


