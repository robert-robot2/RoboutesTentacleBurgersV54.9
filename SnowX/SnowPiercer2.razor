                    @if (particle.IsPixel)
                    {
                        @if (particle.Width == particle.Height)
                        {
                            <circle cx="@particle.X" cy="@particle.Y" r="@(particle.Width / 2)"
                                    fill="@particle.PixelColor" opacity="@particle.Opacity" />
                        }
                        else
                        {
                            <rect x="@particle.X" y="@particle.Y"
                                  width="@particle.Width" height="@particle.Height"
                                  fill="@particle.PixelColor" opacity="@particle.Opacity" />
                        }
                    }
                    else if (!string.IsNullOrEmpty(particle.ImagePath))
                    {
                        <image x="@particle.X" y="@particle.Y"
                               width="@particle.Width" height="@particle.Height"
                               href="@particle.ImagePath" opacity="@particle.Opacity" />
                    }
                }

              
