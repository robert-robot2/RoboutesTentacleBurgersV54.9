                    <script>
                            window.cachedBackgroundImages = {};

    window.cacheBackgroundImage = async (key, path) => {
        if (!window.cachedBackgroundImages[key]) {
            const img = new Image();
            img.src = path;

            await new Promise((resolve, reject) => {
                if (img.complete) {
                    resolve();
                } else {
                    img.onload = resolve;
                    img.onerror = reject;
                }
            });

            window.cachedBackgroundImages[key] = img;
            console.log(`Cached background image: ${key}`);
        }
        return window.cachedBackgroundImages[key];
    };

     window.drawBackgroundLayers = (canvas, layerData, scrollOffset, viewportOffsetX) => {
        const ctx = canvas.getContext('2d');
 
    ctx.clearRect(0, 0, canvas.width, canvas.height);

        for (const layer of layerData) {
            const img = window.cachedBackgroundImages[layer.imageKey];
            if (!img) continue;

            const speed = layer.parallax;

            // World-space scroll (negative = move left)
            const offset = -(scrollOffset + viewportOffsetX) * speed;

            // Smooth remainder (THIS is what was missing)
            const remainder = offset % layer.patternWidth;

            // Start one tile left to guarantee coverage
            let startX = remainder - layer.patternWidth;

            for (
                let x = startX;
                x < canvas.width + layer.patternWidth;
                x += layer.patternWidth
            ) {
              ctx.drawImage(
    img,
    Math.round(x),  // CHANGE: Round x position
    layer.y,
    layer.patternWidth,
    layer.height
);
            }
        }
    };





                    </script>