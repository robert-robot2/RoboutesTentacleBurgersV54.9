@page "/SnowPiercer2"



@using System.Timers
@using Microsoft.AspNetCore.Components.Forms
@implements IDisposable

<PageTitle>SnowPiercer40K!</PageTitle>

<div class="game-container">
    <h1 class="game-title">🚂 SnowPiercer40K! 💀</h1>

    @if (gameState == GameState.Menu)
    {
        <div class="menu-panel">
          
            <!-- HIGH SCORES DISPLAY -->
            <div style="background: rgba(0,0,0,0.8); padding: 20px; border-radius: 10px; margin-bottom: 20px; border: 2px solid #ffd700;">
                <h2 style="color: #ffd700; text-align: center; font-size: 32px; margin-bottom: 20px;">🏆 TOP COMMANDERS 🏆</h2>
                @if (highScores.Count > 0)
                {
                    <div style="font-family: 'Courier New', monospace; color: #0f0;">
                        <div style="display: grid; grid-template-columns: 50px 80px 120px 80px 80px 150px; gap: 10px; padding: 10px; border-bottom: 2px solid #ffd700; margin-bottom: 10px;">
                            <div style="color: #ffd700; font-weight: bold;">RANK</div>
                            <div style="color: #ffd700; font-weight: bold;">NAME</div>
                            <div style="color: #ffd700; font-weight: bold;">SCORE</div>
                            <div style="color: #ffd700; font-weight: bold;">LEVEL</div>
                            <div style="color: #ffd700; font-weight: bold;">KILLS</div>
                            <div style="color: #ffd700; font-weight: bold;">DATE</div>
                        </div>
                        @for (int i = 0; i < highScores.Count; i++)
                        {
                            var hs = highScores[i];
                            var rankColor = i == 0 ? "#FFD700" : i == 1 ? "#C0C0C0" : i == 2 ? "#CD7F32" : "#0f0";
                            <div style="display: grid; grid-template-columns: 50px 80px 120px 80px 80px 150px; gap: 10px; padding: 8px; background: rgba(255,255,255,0.05); margin-bottom: 5px; border-radius: 5px;">
                                <div style="color: @rankColor; font-weight: bold; font-size: 20px;">@(i + 1).</div>
                                <div style="color: @rankColor; font-weight: bold; font-size: 18px;">@hs.Initials</div>
                                <div style="color: #fff; font-size: 16px;">@hs.Score.ToString("N0")</div>
                                <div style="color: #4ecdc4;">@hs.Level</div>
                                <div style="color: #ff6b6b;">@hs.Kills</div>
                                <div style="color: #aaa; font-size: 12px;">@hs.Date.ToString("MM/dd/yy")</div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p style="text-align: center; color: #666; font-style: italic; font-size: 18px;">No high scores yet. Be the first!</p>
                }
            </div>

          

            <div class="menu-center">
                <p class="menu-text">Blast enemies, earn XP, upgrade your Death Train!</p>
                <button class="start-button" @onclick="StartGame">FOR THE EMPEROR!</button>
            </div>
        </div>
    }

    @if (gameState == GameState.Playing)
    {
        <div class="game-ui">
            <div class="stats-bar">
                <span>
                    Engine HP: <b class="stat-score">@(trainCars.FirstOrDefault(c => c.Type == "engine")?.Hp ?? 0) / @carTypes["engine"].MaxHp</b>
                    <span style="color: #0f0; font-size: 12px;">♥ +@EngineRegenAmount/2s</span>
                </span>
                <span>💀 Pixelized: <b class="stat-score">@totalKills</b></span>
                <span>Score: <b class="stat-score">@score</b></span>
                <span>Level: <b class="stat-level">@level</b></span>
                <span>XP: <b class="stat-xp">@xp/@xpNeeded</b></span>
                <span>Throttle: <b class="stat-speed">@((throttle * 100).ToString("F0"))%</b></span> 
                @if (isBuffActive)
                {
                    <span style="color: #FFD700; font-weight: bold; animation: pulse 0.5s infinite;">
                        🐻 BUFF ACTIVE: @((buffExpiresAt - DateTime.Now).TotalSeconds.ToString("F1"))s
                    </span>
                }
                <!-- ADD THESE TWO -->
                <span>🌅 Time: <b class="stat-score">@lightCycle.GetTimeOfDayString()</b></span>
                <span>@lightCycle.GetPhase()</span>
                <span>🌦️ Weather: <b class="stat-score">@weatherCycle.GetWeatherName()</b></span>
            </div>


            @* ADD THIS RIGHT AFTER YOUR STATS BAR TO DEBUG ANIMATIONS: 
            <span>👁️ Visible: <b class="stat-score">@visibleEnemyCount</b></span>
            <span>🚫 Culled: <b class="stat-score">@culledEnemyCount</b></span>
            <div style="margin: 10px 0; padding: 10px; background: rgba(0,0,0,0.5); color: #0f0; font-family: monospace; font-size: 12px;">
                <div><b>🎬 ANIMATION DEBUG:</b></div>
                <div>Total Animations Loaded: @animations.Count</div>
                @foreach (var anim in animations.Take(5))
                {
                    <div>
                        @anim.Key: Frame @anim.Value.CurrentFrame/@(anim.Value.FrameCount - 1)
                        (Width: @anim.Value.TotalWidth)
                    </div>
                }
                @if (animations.ContainsKey("engine_move"))
                {
                    var engineAnim = animations["engine_move"];
                    <div style="color: yellow;">
                        ⚡ Engine: Frame @engineAnim.CurrentFrame -
                        Offset: @(-engineAnim.CurrentFrame * engineAnim.FrameWidth)px
                    </div>
                }
                else
                {
                    <div style="color: red;">❌ engine_move animation NOT FOUND!</div>
                }
            </div>
            *@


            <div style="margin: 10px 0;">
                <label>
                    Throttle Control:
                    <input type="range" min="0" max="100" value="@(throttle * 100)"
                           @oninput="@((ChangeEventArgs e) => throttle = double.Parse(e.Value.ToString()) / 100.0)"
                           style="width: 200px;" />
                </label>
            </div>


            <!-- ADD THIS SECTION -->
            <div style="margin: 10px 0; display: flex; gap: 20px; align-items: center;">
                <button @onclick="() => lightCycle.TogglePause()"
                        style="padding: 5px 15px; cursor: pointer;">
                    @(lightCycle.IsPaused ? "▶️ Resume Day/Night" : "⏸️ Pause Day/Night")
                </button>

                <label>
                    Day/Night Cycle Speed: <b>@lightCycle.CycleDurationMinutes min</b>
                    <input type="range" min="2" max="1440" value="@lightCycle.CycleDurationMinutes"
                           @oninput="@((ChangeEventArgs e) => lightCycle.CycleDurationMinutes = int.Parse(e.Value.ToString()))"
                           style="width: 300px;" />
                    <span style="font-size: 12px; color: #aaa;">
                        (2 min = fast, 1440 min = real-time 24hrs)
                    </span>
                </label>
            </div>

            <!-- Weather & Fog Controls -->
            <div style="margin: 10px 0; display: flex; gap: 20px; align-items: center;">
                <button @onclick="() => weatherCycle.IsWeatherEnabled = !weatherCycle.IsWeatherEnabled"
                        style="padding: 5px 15px; cursor: pointer;">
                    @(weatherCycle.IsWeatherEnabled ? "🌧️ Disable Weather" : "☀️ Enable Weather")
                </button>

                <button @onclick="() => weatherCycle.IsFogEnabled = !weatherCycle.IsFogEnabled"
                        style="padding: 5px 15px; cursor: pointer;">
                    @(weatherCycle.IsFogEnabled ? "🌫️ Disable Fog" : "✨ Enable Fog")
                </button>

                <label>
                    Fog Opacity:
                    <input type="range" min="0" max="100" value="@(weatherCycle.FogOpacity * 100)"
                           @oninput="@((ChangeEventArgs e) => weatherCycle.FogOpacity = double.Parse(e.Value.ToString()) / 100.0)"
                           style="width: 150px;" />
                    <b>@((weatherCycle.FogOpacity * 100).ToString("F0"))%</b>
                </label>
            </div>


            @*Draw 5 canvas layers here outside of the svg viewport to lay all of whtas inside svg on top*@

            <div style="position: relative; width: 1600px; height: 800px;" class="game-board">

                <canvas @ref="backgroundCanvasRef"
                        width="1600"
                        height="800"
                        style="position: absolute; left: 0; top: 0; z-index: 1; pointer-events: none; image-rendering: pixelated;">
