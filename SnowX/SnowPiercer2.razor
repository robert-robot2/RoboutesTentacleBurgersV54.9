                @foreach (var enemy in enemies.Where(e => IsEnemyVisible(e)))
                {
                    var type = enemyTypes[enemy.Type];
                    int enemyX = (int)(enemy.X + viewportOffsetX);

                    // CHECK IF THIS IS A BOSS
                    bool isBoss = enemy.MaxHp >= enemyTypes[enemy.Type].Hp * 9;

                    // SCALE BASED ON HP MULTIPLIER, BUT CAP IT
                    int scale = 1;
                    if (isBoss)
                    {
                        // Calculate scale from HP (HP multiplier of 10 = scale 3, 50 = scale 8, etc)
                        double hpMultiplier = enemy.MaxHp / (double)enemyTypes[enemy.Type].Hp;
                        double rawScale = 2 + (hpMultiplier / 10.0); // Starts at ~3 for 10x HP

                        // Cap scale so enemy doesn't exceed viewport
                        // Viewport height is 800, ground is at 700
                        // Largest enemy (tree) is ~50 pixels tall normally
                        // So max scale = 700 / 50 = 14 (leaves some room)
                        int maxScale = 10; // Conservative cap
                        scale = (int)Math.Min(rawScale, maxScale);
                    }

                    @* Check for animation *@
                    var animKey = GetEnemyAnimationKey(enemy);

                    @if (animations.ContainsKey(animKey))
                    {
                        @* Render animated enemy sprite *@
                        var anim = animations[animKey];
                        <svg x="@enemyX" y="@enemy.Y" width="@(anim.FrameWidth* scale)" height="@(anim.FrameHeight* scale)"
                             viewBox="0 0 @anim.FrameWidth @anim.FrameHeight"
                             overflow="hidden"
                             opacity="@(enemy.MarkedForDeath ? 0.5 : 1.0)">
                            <image x="@(-anim.CurrentFrame * anim.FrameWidth)" y="0"
                                   width="@anim.TotalWidth" height="@anim.FrameHeight"
                                   href="@images[$"enemy{char.ToUpper(enemy.Type[0])}{enemy.Type.Substring(1)}"]"
                                   preserveAspectRatio="xMidYMid slice" />
                        </svg>

                        @* HP Bar for animated sprites *@
                        <rect x="@enemyX" y="@(enemy.Y - 10)" width="@(anim.FrameWidth* scale)" height="@(4 * scale)" fill="#f00" />
                        <rect x="@enemyX" y="@(enemy.Y - 10)" width="@(anim.FrameWidth* scale * enemy.Hp / enemy.MaxHp)" height="@(4 * scale)" fill="#0f0" />
                    }
                    else
                    {
                        @* FALLBACK: Existing geometric rendering *@
                        @if (enemy.Type == "bat")
                        {
                            int wingSpan = 30 * scale;
                            int bodySize = 8 * scale;
                            <polygon points="@($"{enemyX + 15 * scale},{enemy.Y + 10 * scale} {enemyX},{enemy.Y} {enemyX + 10 * scale},{enemy.Y + 5 * scale} {enemyX + 20 * scale},{enemy.Y + 5 * scale} {enemyX + wingSpan},{enemy.Y}")"
                                     fill="@type.Color"
                                     opacity="@(enemy.MarkedForDeath ? 0.5 : 1.0)" />
                            <circle cx="@(enemyX + 15 * scale)" cy="@(enemy.Y + 15 * scale)" r="@bodySize"
                                    fill="@type.Color"
                                    opacity="@(enemy.MarkedForDeath ? 0.5 : 1.0)" />
                            <rect x="@(enemyX + 12 * scale)" y="@(enemy.Y + 13 * scale)" width="@(2 * scale)" height="@(2 * scale)" fill="#ff0000" />
                            <rect x="@(enemyX + 17 * scale)" y="@(enemy.Y + 13 * scale)" width="@(2 * scale)" height="@(2 * scale)" fill="#ff0000" />
                        }
                        else if (enemy.Type == "tree")
                        {
                            <polygon points="@($"{enemyX + 15 * scale},{enemy.Y} {enemyX},{enemy.Y + 30 * scale} {enemyX + 30 * scale},{enemy.Y + 30 * scale}")"
                                     fill="@type.Color"
                                     opacity="@(enemy.MarkedForDeath ? 0.5 : 1.0)" />
                            <rect x="@(enemyX + 12 * scale)" y="@(enemy.Y + 30 * scale)" width="@(6 * scale)" height="@(20 * scale)"
                                  fill="@type.Color"
                                  opacity="@(enemy.MarkedForDeath ? 0.5 : 1.0)" />
                        }
                        else if (enemy.Type == "rock")
                        {
                            <circle cx="@(enemyX + 15 * scale)" cy="@(enemy.Y + 25 * scale)" r="@(15 * scale)"
                                    fill="@type.Color"
                                    opacity="@(enemy.MarkedForDeath ? 0.5 : 1.0)" />
                        }
                        else
                        {
                            <rect x="@enemyX" y="@enemy.Y" width="@(30 * scale)" height="@(40 * scale)"
                                  fill="@type.Color"
                                  opacity="@(enemy.MarkedForDeath ? 0.5 : 1.0)" />
                            <rect x="@(enemyX + 8 * scale)" y="@(enemy.Y + 10 * scale)" width="@(5 * scale)" height="@(5 * scale)" fill="#fff" />
                            <rect x="@(enemyX + 17 * scale)" y="@(enemy.Y + 10 * scale)" width="@(5 * scale)" height="@(5 * scale)" fill="#fff" />
                        }

                        @* HP Bar - scaled for bosses (fallback rendering) *@
                        <rect x="@enemyX" y="@(enemy.Y - 10)" width="@(30 * scale)" height="@(4 * scale)" fill="#f00" />
                        <rect x="@enemyX" y="@(enemy.Y - 10)" width="@(30 * scale * enemy.Hp / enemy.MaxHp)" height="@(4 * scale)" fill="#0f0" />
                    }
                }



                @* Rotating Weapon Fireballs (China Cart) *@
                @for (int idx = 0; idx < trainCars.Count; idx++)
                {
                    var car = trainCars[idx];
                    if (car.Type != "china") continue;

                    var carInfo = carTypes[car.Type];
                    if (!carRotationAngles.ContainsKey(idx)) continue;

                    int carX = (int)(50 + idx * 192 + 96 + viewportOffsetX);
                    int carY = 660 + 32;

                    double currentAngle = carRotationAngles[idx];
                    double angleRadians = currentAngle * Math.PI / 180.0;

                    int fireballCount = carInfo.ProjectileCount;
                    double maxDistance = carInfo.ScatterCount;

                    @for (int f = 0; f < fireballCount; f++)
                    {
                        double distanceFromCenter = (maxDistance / (fireballCount - 1)) * f;
                        double fireballX = carX + Math.Cos(angleRadians) * distanceFromCenter;
                        double fireballY = carY + Math.Sin(angleRadians) * distanceFromCenter;

                        @* Check if we have fireball animation *@
                        var fireballAnimKey = "effect_china";

                        @if (animations.ContainsKey(fireballAnimKey))
                        {
                            @* Animated fireball *@
                            var anim = animations[fireballAnimKey];
                            <svg x="@(fireballX - anim.FrameWidth / 2)" y="@(fireballY - anim.FrameHeight / 2)"
                                 width="@anim.FrameWidth" height="@anim.FrameHeight"
                                 viewBox="0 0 @anim.FrameWidth @anim.FrameHeight"
                                 overflow="hidden">
                                <image x="@(-anim.CurrentFrame * anim.FrameWidth)" y="0"
                                       width="@anim.TotalWidth" height="@anim.FrameHeight"
                                       href="@images["projChina"]"
                                       preserveAspectRatio="xMidYMid slice" />
                            </svg>
                        }
                        else if (!string.IsNullOrEmpty(images.GetValueOrDefault("projChina")))
                        {
                            @* Static fireball image *@
                            <image x="@(fireballX - carInfo.ProjectileWidth / 2)"
                                   y="@(fireballY - carInfo.ProjectileHeight / 2)"
                                   width="@carInfo.ProjectileWidth"
                                   height="@carInfo.ProjectileHeight"
                                   href="@images["projChina"]" />
                        }
                        else
                        {
                            @* Fallback: orange circle *@
                            <circle cx="@fireballX" cy="@fireballY"
                                    r="@(carInfo.ProjectileWidth / 2)"
                                    fill="#FF4500"
                                    stroke="#FF8C00"
                                    stroke-width="2" />
                        }
                    }
                }
         

                @* Effects *@
                @foreach (var effect in effects.Where(e => IsEffectVisible(e) && e.IsVisible))
                {
                    var projKey = $"proj{char.ToUpper(effect.Type[0])}{effect.Type.Substring(1)}";
                    double effectX = effect.X + viewportOffsetX;

                    @* 🚁 DRONE HP BAR (only for drones with HP) *@
                    @if (effect.Type == "drone" && effect.MaxHp > 0 && effect.Hp > 0)
                    {
                        <rect x="@(effectX - 20)" y="@(effect.Y - 15)" width="40" height="4" fill="#f00" />
                        <rect x="@(effectX - 20)" y="@(effect.Y - 15)" width="@(40 * effect.Hp / effect.MaxHp)" height="4" fill="#0f0" />
                    }
                    @* Check if this projectile has an animation *@
                    var effectAnimKey = $"effect_{effect.Type}";

                    @if (animations.ContainsKey(effectAnimKey))
                    {
                        @* Animated projectile WITH ROTATION *@
                        var anim = animations[effectAnimKey];
                        <g transform="translate(@effectX, @effect.Y) rotate(@effect.RotationAngle) translate(@(-anim.FrameWidth / 2), @(-anim.FrameHeight / 2))">
                            <svg width="@anim.FrameWidth" height="@anim.FrameHeight"
                                 viewBox="0 0 @anim.FrameWidth @anim.FrameHeight"
                                 overflow="hidden">
                                <image x="@(-anim.CurrentFrame * anim.FrameWidth)" y="0"
                                       width="@anim.TotalWidth" height="@anim.FrameHeight"
                                       href="@images[projKey]"
                                       preserveAspectRatio="xMidYMid slice" />
                            </svg>
                        </g>
                    }
                    else if (!string.IsNullOrEmpty(images.GetValueOrDefault(projKey)))
                    {
                        @* Static projectile image WITH ROTATION *@
                        <image x="@(effectX - effect.Width / 2)" y="@(effect.Y - effect.Height / 2)"
                               width="@effect.Width" height="@effect.Height"
                               href="@images[projKey]"
                               transform="rotate(@effect.RotationAngle, @effectX, @effect.Y)" />
                    }
                    else
                    {
                        @* Fallback colored circle (no rotation needed for circles) *@
                        var carColor = GetCarColor(effect.Type);
                        <circle cx="@effectX" cy="@effect.Y" r="@(effect.Width / 2)" fill="@carColor" />
                    }
                }

                @* Enemy Projectiles *@
                @foreach (var proj in enemyProjectiles.Where(p => p.X + viewportOffsetX > -50 && p.X + viewportOffsetX < 1650))
                {
                    double projX = proj.X + viewportOffsetX;

                    // 🆕 CALCULATE ROTATION ANGLE FROM VELOCITY
                    double rotationAngle = Math.Atan2(proj.VelocityY, proj.VelocityX) * (180.0 / Math.PI);

                    // Check for sprite image
                    var projKey = $"enemyProj_{proj.Type}";

                    // Check for animation
                    var animKey = $"enemyEffect_{proj.Type}";

                    @if (animations.ContainsKey(animKey))
                    {
                        @* 🆕 ANIMATED SPRITE WITH ROTATION *@
                        var anim = animations[animKey];
                        <g transform="translate(@projX, @proj.Y) rotate(@rotationAngle) translate(@(-anim.FrameWidth / 2), @(-anim.FrameHeight / 2))">
                            <svg width="@anim.FrameWidth" height="@anim.FrameHeight"
                                 viewBox="0 0 @anim.FrameWidth @anim.FrameHeight"
                                 overflow="hidden">
                                <image x="@(-anim.CurrentFrame * anim.FrameWidth)" y="0"
                                       width="@anim.TotalWidth" height="@anim.FrameHeight"
                                       href="@images[projKey]"
                                       preserveAspectRatio="xMidYMid slice" />
                            </svg>
                        </g>
                    }
                    else if (!string.IsNullOrEmpty(images.GetValueOrDefault(projKey)))
                    {
                        @* STATIC SPRITE WITH ROTATION *@
                        <image x="@(projX - proj.Width / 2)" y="@(proj.Y - proj.Height / 2)"
                               width="@proj.Width" height="@proj.Height"
                               href="@images[projKey]"
                               transform="rotate(@rotationAngle, @projX, @proj.Y)" />
                    }
                    else
                    {
                        @* FALLBACK: Red circle with direction indicator *@
                        <circle cx="@projX" cy="@proj.Y" r="@(proj.Width / 2)"
                                fill="#ff0000" stroke="#ff6666" stroke-width="2"
                                opacity="0.8" />
                        @* Direction indicator line *@
                        <line x1="@projX" y1="@proj.Y"
                              x2="@(projX + Math.Cos(rotationAngle * Math.PI / 180) * 15)"
                              y2="@(proj.Y + Math.Sin(rotationAngle * Math.PI / 180) * 15)"
                              stroke="#ffffff" stroke-width="2" />
                    }
                }



                @* ===== FOLIAGE LAYER 3 (Foreground - In Front of Train) ===== *@

                @*
                @if (!string.IsNullOrEmpty(images.GetValueOrDefault(GetFoliageLayer3ImageKey())))
                {
