<script>
    window.getElementRect = (el) => {
        const r = el.getBoundingClientRect();
        return { left: r.left, top: r.top, width: r.width, height: r.height };
    };

    // ? NEW: Minimap-specific helper
    window.getMinimapRect = (el) => {
        const r = el.getBoundingClientRect();
        return {
            left: r.left,
            top: r.top,
            width: r.width,
            height: r.height
        };
    };




        // ? ADD: Cache the atlas image globally
    window.cachedAtlasImage = null;
    window.cachedAtlasPath = null;

    window.drawTilesToCanvas = async (canvas, atlasPath, tileData) => {
        const ctx = canvas.getContext('2d');

        // ? Load and cache atlas image ONCE
        if (!window.cachedAtlasImage || window.cachedAtlasPath !== atlasPath) {
            const atlasImage = new Image();
            atlasImage.src = atlasPath;

            await new Promise((resolve, reject) => {
                if (atlasImage.complete) {
                    resolve();
                } else {
                    atlasImage.onload = resolve;
                    atlasImage.onerror = reject;
                }
            });

            window.cachedAtlasImage = atlasImage;
            window.cachedAtlasPath = atlasPath;
        }

        // ? Now clear and redraw instantly (no loading delay)
        ctx.clearRect(0, 0, canvas.width, canvas.height);

        for (const tile of tileData) {
            ctx.drawImage(
                window.cachedAtlasImage,  // ? Use cached image
                tile.atlasX, tile.atlasY, 32, 32,
                tile.x, tile.y, 32, 32
            );
        }
    };


</script>



