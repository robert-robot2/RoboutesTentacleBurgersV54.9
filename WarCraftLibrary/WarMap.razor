        <div style="
            position:absolute;
            left:@(dropX - Game.CameraX)px;
            top:@(dropY - Game.CameraY)px;
            width:@peasant.Width;
            height:@peasant.Height;
            border:2px solid lime;
            background-color:rgba(0,255,0,0.2);
            pointer-events:none;
            z-index:10000;">
        </div>
    }

        
    }
}


    }

    <!-- ? DRAG SELECTION BOX -->
    @if (isDragging)
    {
        <div style="position: absolute;
                    left: @(Math.Min(dragStartX, dragCurrentX) - Game.CameraX)px;
                    top: @(Math.Min(dragStartY, dragCurrentY) - Game.CameraY)px;
                    width: @(Math.Abs(dragCurrentX - dragStartX))px;
                    height: @(Math.Abs(dragCurrentY - dragStartY))px;
                    border: 2px dashed #0F0;
                    background: rgba(0, 255, 0, 0.1);
                    pointer-events: none;
                    z-index: 999;">
        </div>
    }


    @* ? SVG FOG OF WAR OVERLAY *@
    @if (Game.FogOfWarEnabled)
    {
        var visionCircles = GetVisionCircles();

        <svg width="1024" height="768"
             style="position:absolute; top:0; left:0; pointer-events:none; z-index:100;">
            <defs>
                <mask id="fogMask">
                    @* ? INVERTED: White = show fog, Black circles = clear vision *@
                    <rect width="1024" height="768" fill="white" />

                    @* Draw BLACK circles to "cut out" fog where vision is *@
                    @foreach (var (x, y, radius) in visionCircles)
                    {
                        <circle cx="@x" cy="@y" r="@radius" fill="black" />
                    }
                </mask>
            </defs>

            @* Black fog with inverted mask applied *@
            <rect width="1024" height="768" fill="black" opacity="0.7" mask="url(#fogMask)" />
        </svg>
    }
    <button class="menu-btn" @onclick="ReturnToMenu">Menu</button>


