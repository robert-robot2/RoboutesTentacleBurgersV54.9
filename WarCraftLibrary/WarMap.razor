@page "/WarMap"


<PageTitle>WarCraft - @(Game.CurrentMap?.MapName ?? "Battle")</PageTitle>
<div class="DiabloBlueGlow" style="font-size:150%">WarCraft</div>


@using WarCraftLibrary

@inject WarGameService Game
@inject NavigationManager NavManager


  

    <!-- Main Viewport (800x600) -->
<div class="war-viewport" @ref="viewportRef" @onkeydown="HandleKeyDown"
     @onkeyup="HandleKeyUp"
     @onmousemove="HandleMouseMove"
     @onmouseleave="HandleMouseLeave"
     @onmousedown="HandleMouseDown"
     @onmouseup="HandleMouseUp"
     @onclick="HandleClick"
     @onclick:preventDefault="Game.IsBuildMode"
     @oncontextmenu="HandleRightClick"
     @oncontextmenu:preventDefault="true"
     tabindex="0">
     <button class="menu-btn" @onclick="ReturnToMenu">Menu</button>


    <div class="war-map" style="left:@Game.ViewportXpx; top:@Game.ViewportYpx;">

        <!-- ===== CANVAS TILE LAYER ===== -->
        @if (Game.TileMap != null && Game.TileAtlas != null)
        {
            // Trigger canvas redraw
            _ = DrawTilesToCanvas();

            <canvas @ref="tileCanvasRef"
                    width="4096"
                    height="4096"
                    style="position:absolute; left:0; top:0; pointer-events:none; image-rendering: pixelated;">
            </canvas>

        }
     
        <!-- Gold Mines (CULLED) -->
        @foreach (var mine in WarRegistry.GoldMines)
        {
            @if (Game.IsEntityVisible(mine.PosX, mine.PosY, mine.Width, mine.Height, 32))
            {
                <div style="@mine.EntityStyle">
                    <img src="@mine.SpritePath" style="width:100%; height:100%;" alt="@mine.PlaceholderName" />
                </div>
            }
        }
        <!-- Trees (CULLED) -->
        @foreach (var tree in WarRegistry.Trees)
        {
            @if (Game.IsEntityVisible(tree.PosX, tree.PosY, tree.Width, tree.Height, 32))
            {
                <div style="@tree.EntityStyle">
                    <img src="@tree.SpritePath" style="width:100%; height:100%;" alt="@tree.PlaceholderName" />
                </div>
            }
        }
        <!-- Buildings (CULLED) -->
        @foreach (var building in WarRegistry.Buildings)
        {
            @if (Game.IsEntityVisible(building, 32))
            {
@* Determine if building belongs to player/allies *@

    bool isPlayerOwned = building.OwnerPlayerIndex == 0;
    
    // FFA Mode: Team = 0, everyone is enemy except player
    // Team Mode: Team > 0, same team = ally
    bool isAlly = false;
    
    if (building.OwnerTeam == 0)
    {
        // FFA: No allies except yourself
        isAlly = false;
    }
    else if (Game.Players.Count > 0 && building.OwnerTeam == Game.Players[0].Team)
    {
        // Team mode: Same team = ally
        isAlly = true;
    }
    else if (Game.Players.Count == 0 && building.Race == Game.PlayerFaction?.Race)
    {
        // Legacy mode fallback
        isAlly = true;
    }
    
    bool isEnemy = !isPlayerOwned && !isAlly;


@if (isPlayerOwned || isAlly || !Game.FogOfWarEnabled || (isEnemy && FogOfWar.IsEntityVisible(building, Game)))
{
                    @* ? PHASE 4: Get current animated sprite *@
                    var currentSprite = BuildingAnimationController.GetCurrentSprite(building);
                    var constructionProgress = BuildingAnimationController.GetConstructionProgressPercentage(building);
                    var hpPercentage = BuildingAnimationController.GetHPPercentage(building);

                    <div style="@building.EntityStyle;" class="@(building.IsSelected ? "entity-selected" : "")">

                        @* ? PHASE 4: Use animated sprite with state-based opacity *@
                        <img src="@currentSprite"
                             style="width:100%; height:100%;
                                        @(building.CurrentBuildingState == BuildingAnimationState.Destroyed ? "opacity:0.3;" : "")"
                             alt="@building.PlaceholderName" />

                        @* Selection box *@
                        @if (building.IsSelected)
                        {
                            <div class="selection-box"></div>
                        }

                        @* ? PHASE 4: Construction progress indicator *@
                        @if (building.CurrentBuildingState == BuildingAnimationState.Constructing)
                        {
                            <div class="construction-overlay DiabloRedGlowWarMap">
                                Building... @constructionProgress%
                            </div>

                            @* Optional: Construction progress bar *@
                            <div style="position:absolute; bottom:0; left:0; right:0; height:4px; background:rgba(0,0,0,0.7);">
                                <div style="height:100%; background:#0F0; width:@(constructionProgress)%;"></div>
                            </div>
                        }

                        @* ? PHASE 4: HP bar for damaged buildings *@
                        @if (building.CurrentBuildingState == BuildingAnimationState.Damaged && building.IsSelected)
                        {
                            <div style="position:absolute; bottom:-8px; left:0; right:0; height:3px; background:rgba(0,0,0,0.8);">
                                <div style="height:100%;
                                                        background:@(hpPercentage > 50 ? "#0F0" : hpPercentage > 25 ? "#FF0" : "#F00");
                                                        width:@(hpPercentage)%;"></div>
                            </div>
                        }

                        @* ? PHASE 4: Damage effects (smoke/fire) *@
                        @if (BuildingAnimationController.ShouldShowSmoke(building))
                        {
                            <div class="smoke-effect">??</div>
                        }
                        @if (BuildingAnimationController.ShouldShowFire(building))
                        {
                            <div class="fire-effect">??</div>
                        }

                        @* ? PHASE 4: Destroyed indicator *@
                        @if (building.CurrentBuildingState == BuildingAnimationState.Destroyed)
                        {
                            <div class="destroyed-overlay">DESTROYED</div>
                        }
                    </div>
                }
            }
        }

        <!-- Units (CULLED) -->
        @foreach (var unit in WarRegistry.Units)
        {
            @if (Game.IsEntityVisible(unit, 32))
            {
                @* ? NEW: Only show if player's unit, ally unit, OR visible through fog *@
@* Determine if unit belongs to player/allies *@

    bool isPlayerOwned = unit.OwnerPlayerIndex == 0;
    
    // FFA Mode: Team = 0, everyone is enemy except player
    // Team Mode: Team > 0, same team = ally
    bool isAlly = false;
    
    if (unit.OwnerTeam == 0)
    {
        // FFA: No allies except yourself
        isAlly = false;
    }
    else if (Game.Players.Count > 0 && unit.OwnerTeam == Game.Players[0].Team)
    {
        // Team mode: Same team = ally
        isAlly = true;
    }
    else if (Game.Players.Count == 0 && unit.Race == Game.PlayerFaction?.Race)
    {
        // Legacy mode fallback
        isAlly = true;
    }
    
    bool isEnemy = !isPlayerOwned && !isAlly;


@if (isPlayerOwned || isAlly || !Game.FogOfWarEnabled || (isEnemy && FogOfWar.IsEntityVisible(unit, Game)))
{
                    var spriteSheetPath = WarAnimations.GetAnimatedSpritePath(unit);
                    var config = GetAnimationConfig(unit.CurrentAnimationState);
                    var frameOffsetX = unit.AnimationFrame * -32;

                    <div style="@unit.EntityStyle" class="@(unit.IsSelected ? "entity-selected" : "")">
                        <!-- Animated Sprite with frame offset -->
                        <div style="width:@(unit.Width)px; height:@(unit.Height)px; overflow:hidden;">
                            <img src="@spriteSheetPath"
                                 style="width:@(config.FrameCount* unit.Width)px; height:@(unit.Height)px;
                            object-fit:none;
                            object-position:@(frameOffsetX)px 0px;"
                                 alt="@unit.PlaceholderName" />
                        </div>

                        @if (unit.IsSelected)
                        {
                            <div class="selection-circle"></div>
                        }

                        @if (unit.CarryingGold > 0)
                        {
                            <img src="/wc1sprites/ui/Gold001.png" class="carrying-indicator" alt="Gold" />
                        }
                        @if (unit.CarryingLumber > 0)
                        {
                            <img src="/wc1sprites/ui/Woood001.png" class="carrying-indicatorL" alt="Lumber" />
                        }
                    </div>
                }
            }
        }
 
        <!-- Projectiles (CULLED) -->
        @foreach (var projectile in WarRegistry.Projectiles)
        {
            @if (Game.IsEntityVisible(projectile, 32))
            {
                <div style="@projectile.EntityStyle">
                    <img src="@projectile.SpritePath"
                         style="width:100%; height:100%;"
                         alt="@projectile.PlaceholderName" />
                </div>
            }
        }

        <!-- ? PART 2: Rally Point Flags -->
        @foreach (var building in WarRegistry.Buildings)
        {
          
    bool rallyIsPlayerOwned = building.OwnerPlayerIndex == 0;
    bool rallyIsAlly = false;
    
    if (building.OwnerTeam == 0)
    {
        rallyIsAlly = false; // FFA
    }
    else if (Game.Players.Count > 0 && building.OwnerTeam == Game.Players[0].Team)
    {
        rallyIsAlly = true; // Team mode
    }
    else if (Game.Players.Count == 0 && building.Race == Game.PlayerFaction?.Race)
    {
        rallyIsAlly = true; // Legacy
    }


@if (building.HasCustomRallyPoint &&
        (rallyIsPlayerOwned || rallyIsAlly) &&
        Game.IsEntityVisible(building.RallyX, building.RallyY, 32, 32, 32))
{
                <div style="position:absolute;
                            left:@(building.RallyX - 16)px;
                            top:@(building.RallyY - 32)px;
                            width:32px;
                            height:32px;
                            pointer-events:none;
                            z-index:50;">
                    <!-- Flag emoji or you can use a sprite -->
                    <div class="rally-flag" style="font-size:28px; text-shadow: 2px 2px 4px rgba(0,0,0,0.8);">
                        ??
                    </div>
                </div>
            }
        }

        <!-- Ghost Building (placement preview) -->
        @if (Game.IsBuildMode && Game.GhostBuildingPosition != null)
        {
            var ghostClass = Game.IsGhostPlacementValid ? "ghost-valid" : "ghost-invalid";
            var ghostColor = Game.IsGhostPlacementValid ? "rgba(0,255,0,0.3)" : "rgba(255,0,0,0.3)";
            var borderColor = Game.IsGhostPlacementValid ? "#0F0" : "#F00";

            int ghostSize = Game.BuildingToBuild switch
            {
                "Road" => 32,
                "Farm" => 64,
                "WoodenWall" => 32,     // ? NEW
                "StoneWall" => 32,      // ? NEW
                "WoodTower" => 64,      // ? NEW
                "StoneTower" => 64,     // ? NEW
                    "Church" => 96,         // ? NEW
    "CultistHut" => 96,     // ? NEW
                "Barracks" => 128,
                "LumberMill" => 96,
                "ArcheryRange" => 128,
                "Blacksmith" => 96,
                "Stables" => 64,      // ? NEW: 2x2 grid
                "Pen" => 64,          // ? NEW: 2x2 grid
                "KnightsHold" => 96,  // ? NEW: 2x2 grid
                "RaiderLair" => 96,   // ? NEW: 2x2 grid
                _ => 128
            };

            <div style="position:absolute;
                left:@(Game.GhostBuildingPosition.Value.x)px;
                top:@(Game.GhostBuildingPosition.Value.y)px;
                width:@(ghostSize)px;
                height:@(ghostSize)px;
                border:3px dashed @borderColor;
                background:@ghostColor;
                pointer-events:none;
                z-index:999;">

                <!-- Show building sprite at 50% opacity -->
                @if (Game.BuildingToBuild == "Barracks")
                {
                    <img src="@GetBuildingSprite()"
                         style="width:100%; height:100%; opacity:0.5;" />
                }

                <!-- Show text indicator -->
                <div style="position:absolute; bottom:-25px; left:0; right:0;
                        text-align:center; color:@borderColor; font-weight:bold;">
                    @(Game.IsGhostPlacementValid ? "? Valid" : "? Invalid")
                </div>
            </div>
        }






        </div>

