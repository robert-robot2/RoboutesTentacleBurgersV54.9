    <WarUI @ref="warUI" />
    <TechTree @ref="techTree" />
    @* ? OPTIONAL: Fog of War Debug Indicator *@
    @if (!Game.FogOfWarEnabled)
    {
        <div style="position:absolute; top:50px; right:10px;
                    background:rgba(0,255,0,0.8); color:#000;
                    padding:8px 12px; font-weight:bold; font-size:14px;
                    border:2px solid #0F0; z-index:9999; pointer-events:none;">
            FOG OF WAR: OFF (F3)
        </div>
    }
    <!-- Debug Grid -->
    @if (Game.ShowDebugGrid)
    {
        <div class="debug-grid">
            @for (int x = 0; x < Game.GridWidth; x++)
            {
                for (int y = 0; y < Game.GridHeight; y++)
                {
                    <div style="position:absolute; left:@(x * 32)px; top:@(y * 32)px; width:32px; height:32px; border:1px solid rgba(255,255,255,0.1); pointer-events:none;"></div>
                }
            }
        </div>

    }
    @if (Game.ShowDebugInfo)
    {
        int tilesRendered = Game.CachedVisibleTiles.Count;
        <div class="debug-info">
            <div>Camera: (@Game.CameraX, @Game.CameraY)</div>
            <div>Buildings: @WarRegistry.Buildings.Count</div>
            <div>Units: @WarRegistry.Units.Count</div>
            <div>Gold: @Game.PlayerGold | Lumber: @Game.PlayerLumber</div>
            <div>Selected: @(WarRegistry.SelectedBuilding?.PlaceholderName ?? WarRegistry.SelectedUnits.FirstOrDefault()?.PlaceholderName ?? "None")</div>
            <!-- ADD THESE LINES -->
                    int tilesRendered = Game.CachedVisibleTiles.Count;
            ?? TILES: @tilesRendered / @(Game.TileMap.GridWidth* Game.TileMap.GridHeight)<br />
            <div style="color: cyan">ViewportXpx: @Game.ViewportXpx</div>
            <div style="color: cyan">ViewportYpx: @Game.ViewportYpx</div>
            <!-- END NEW LINES -->

            <div>Trees: @WarRegistry.Trees.Count</div>
            <div>Gold Mines: @WarRegistry.GoldMines.Count</div>
            <div>Last Click: (@lastClickWorldX, @lastClickWorldY)</div>
            <div>Last Grid: (@lastClickGridX, @lastClickGridY)</div>
            <div style="position:absolute; top:400px; right:10px; z-index:9999; background:rgba(0,0,0,0.8); color:#0F0; padding:10px; font-size:11px; max-height:300px; overflow-y:auto;">
                <strong>?? UNIT OWNERSHIP DEBUG:</strong><br />
                @foreach (var unit in WarRegistry.Units.Take(10))
                {
                    <div style="color: @(unit.OwnerPlayerIndex == 0 ? "#0F0" : "#F00")">
                        @unit.PlaceholderName: Owner=@unit.OwnerPlayerIndex, Team=@unit.OwnerTeam, Race=@unit.Race
                    </div>
                }
                <br />
                <strong>?? BUILDING OWNERSHIP DEBUG:</strong><br />
                @foreach (var building in WarRegistry.Buildings.Take(10))
                {
                    <div style="color: @(building.OwnerPlayerIndex == 0 ? "#0F0" : "#F00")">
                        @building.PlaceholderName: Owner=@building.OwnerPlayerIndex, Team=@building.OwnerTeam, Race=@building.Race
                    </div>
                }
            </div>
            <!-- ADD SELECTION INFO -->
            <div>
                Selected: @(WarRegistry.SelectedBuilding?.PlaceholderName ??
                            WarRegistry.SelectedUnits.FirstOrDefault()?.PlaceholderName ??
                            "None")
            </div>
            <!-- END NEW LINE -->

            <div style="color: @(Game.IsEdgeScrolling ? "#FF0" : "#0F0")">
                Edge Scroll: @(Game.IsEdgeScrolling ? "ACTIVE" : "OFF")
                @if (Game.ScrollingUp)
                {
                    <span> ?</span>
                }
                @if (Game.ScrollingDown)
                {
                    <span> ?</span>
                }
                @if (Game.ScrollingLeft)
                {
                    <span> ?</span>
                }
                @if (Game.ScrollingRight)
                {
                    <span> ?</span>
                }
            </div>
        </div>
        <!-- Draw Buildings -->
        @foreach (var building in WarRegistry.Buildings)
        {
            <div style="
                    position:absolute;
                    left:@(building.PosX - Game.CameraX)px;
                    top:@(building.PosY - Game.CameraY)px;
                    width:@building.Width;
                    height:@building.Height;
                    border:2px solid rgba(0,255,0,0.7);
                    pointer-events:none;">
            </div>
        }

        <!-- Draw Units -->
        @foreach (var unit in WarRegistry.Units)
        {
            <div style="
                    position:absolute;
                    left:@(unit.PosX - Game.CameraX)px;
                    top:@(unit.PosY - Game.CameraY)px;
                    width:@unit.Width;
                    height:@unit.Height;
                    border:2px solid rgba(0,0,255,0.7);
                    pointer-events:none;">
            </div>
        }
        <!-- Draw Click Boxes (red) -->
        @foreach (var building in WarRegistry.Buildings)
        {
            <div style="
                    position:absolute;
                    left:@(building.PosX - Game.CameraX)px;
                    top:@(building.PosY - Game.CameraY)px;
                    width:@building.Width;
                    height:@building.Height;
                    border:2px dashed rgba(255,0,0,0.9);
                    background:rgba(255,0,0,0.1);
                    pointer-events:none;">
                <span style="position:absolute; top:0; left:0; font-size:10px; color:#FFF;">@building.PlaceholderName</span>
            </div>
        }

        @foreach (var unit in WarRegistry.Units)
        {
            <div style="
                    position:absolute;
                    left:@(unit.PosX - Game.CameraX)px;
                    top:@(unit.PosY - Game.CameraY)px;
                    width:@unit.Width;
                    height:@unit.Height;
                    border:2px dashed rgba(255,128,0,0.9);
                    background:rgba(255,128,0,0.1);
                    pointer-events:none;">
                <span style="position:absolute; top:0; left:0; font-size:10px; color:#FFF;">@unit.PlaceholderName</span>
            </div>
        }
        <!-- Hover Highlight for Clicked Entity -->
        @if (hoveredBuilding != null)
        {
            <div style="
                position:absolute;
                left:@(hoveredBuilding.PosX - Game.CameraX)px;
                top:@(hoveredBuilding.PosY - Game.CameraY)px;
                width:@hoveredBuilding.Width;
                height:@hoveredBuilding.Height;
                border:3px solid yellow;
                background:rgba(255,255,0,0.2);
                pointer-events:none;
                z-index:1000;">
                <span style="position:absolute; top:0; left:0; font-size:12px; color:#000;">
                    @hoveredBuilding.PlaceholderName
                </span>
            </div>
        }

        @if (hoveredUnit != null)
        {
            <div style="
                position:absolute;
                left:@(hoveredUnit.PosX - Game.CameraX)px;
                top:@(hoveredUnit.PosY - Game.CameraY)px;
                width:@hoveredUnit.Width;
                height:@hoveredUnit.Height;
                border:3px solid orange;
                background:rgba(255,165,0,0.2);
                pointer-events:none;
                z-index:1000;">
                <span style="position:absolute; top:0; left:0; font-size:12px; color:#000;">
                    @hoveredUnit.PlaceholderName
                </span>
            </div>
        }
