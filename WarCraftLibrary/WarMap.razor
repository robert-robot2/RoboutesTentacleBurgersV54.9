@foreach (var peasant in WarRegistry.Units.OfType<Peasant>())
{
    if (peasant.TargetTownHall != null)
    {
        var building = peasant.TargetTownHall;

     
          // Drop-off point rectangle (green)

    if (peasant.TargetTownHall != null)
    {
        var b = peasant.TargetTownHall;

        // Simple logic: drop at nearest edge to peasant
        int dropX = peasant.PosX < b.PosX ? b.PosX - peasant.Width : 
